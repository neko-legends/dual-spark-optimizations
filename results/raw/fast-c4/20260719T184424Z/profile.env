# Experimental C4 variant of the Tony-derived runtime with drowzeys v1.1 weights.
# Keep separate from fast.env until matched C1/C4 measurements establish whether
# allowing four live sequences changes single-stream speed or remains stable.
DSPARK_VLLM_IMAGE=dual-spark-vllm:fast-tony-overlay
KV_CACHE_DTYPE=fp8
MAX_MODEL_LEN=900000
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.80
MTP_NUM_TOKENS=5
THINKING=false
ENABLE_PREFIX_CACHING=1
ENABLE_FLASHINFER_AUTOTUNE=1
DSPARK_PRIVILEGED=false
