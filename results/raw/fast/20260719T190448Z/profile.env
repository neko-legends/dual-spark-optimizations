# Experimental hybrid: drowzeys v1.1 weights + Tony-derived fast overlay.
# Tony's published ~62.48 tok/s result used stock weights. Benchmark this hybrid
# before making any performance claim about it.
DSPARK_VLLM_IMAGE=dual-spark-vllm:fast-tony-overlay
KV_CACHE_DTYPE=fp8
MAX_MODEL_LEN=900000
MAX_NUM_SEQS=1
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.80
MTP_NUM_TOKENS=5
THINKING=false
ENABLE_PREFIX_CACHING=1
ENABLE_FLASHINFER_AUTOTUNE=1
DSPARK_PRIVILEGED=false
