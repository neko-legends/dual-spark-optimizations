# Reference v1.1 profile based on drowzeys' published 1M/C4 recipe.
DSPARK_VLLM_IMAGE=dual-spark-vllm:drowzeys-stage-c
UPSTREAM_RUNTIME_IMAGE=ghcr.io/drowzeys/vllm-dspark-nvfp4-stage-c:gb10
KV_CACHE_DTYPE=nvfp4_ds_mla
MAX_MODEL_LEN=1048576
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.85
MTP_NUM_TOKENS=5
THINKING=false
ENABLE_PREFIX_CACHING=
ENABLE_FLASHINFER_AUTOTUNE=
DSPARK_PRIVILEGED=true
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
