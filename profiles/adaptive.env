# Recommended general-purpose profile: use Tony's single-request hot path when
# one request is active and switch automatically to stable-slot C4 batching for
# overlapping requests. No client or agent changes are required.
DSPARK_VLLM_IMAGE=dual-spark-vllm:fast-tony-overlay
KV_CACHE_DTYPE=fp8
MAX_MODEL_LEN=900000
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.80
MTP_NUM_TOKENS=5
THINKING=false
ENABLE_PREFIX_CACHING=1
ENABLE_FLASHINFER_AUTOTUNE=1
DSPARK_PRIVILEGED=false
